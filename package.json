{
  "name": "macos-simulator",
  "version": "1.0.0",
  "description": "MacOS Simulator desktop wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.jason.macos-simulator",
    "productName": "MacOS Simulator",
    "files": [
      "main.js",
      "web-dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12"
  }
}
